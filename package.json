{
  "name": "AIUIPipeline",
  "version": "1.0.0",
  "description": "AI-powered game UI generation pipeline - PSD to Unity/Cocos2dx code generation using DeepSeek API",
  "main": "backend_api.py",
  "scripts": {
    "start": "python backend_api.py",
    "dev": "uvicorn backend_api:app --reload --port 8000"
  },
  "dependencies": {
    "fastapi": "^0.104.0",
    "uvicorn": "^0.24.0",
    "openai": "^1.3.0",
    "psd-tools": "^1.9.0",
    "pillow": "^10.0.0",
    "python-multipart": "^0.0.6"
  },
  "frontend": {
    "tool": "react",
    "entry": "index.html",
    "framework": "html+vanilla-js"
  },
  "engines": {
    "python": ">=3.8"
  },
  "keywords": [
    "game-ui",
    "psd-parser",
    "code-generation",
    "unity",
    "cocos2dx",
    "ai-assisted",
    "ui-automation",
    "deepseek-api"
  ],
  "author": "AIUIPipeline Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiuipipeline/core"
  }
}
